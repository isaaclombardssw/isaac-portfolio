# Copy to .env.local (gitignored) and fill in. Never commit real values.

# Resend — contact form delivery (https://resend.com)
# Free tier needs no domain while you send to your own account email using the
# default onboarding@resend.dev sender.
RESEND_API_KEY=
# Where lead emails land (your inbox):
CONTACT_TO_EMAIL=
# Optional: custom sender once you've verified a domain in Resend.
# CONTACT_FROM_EMAIL="Isaac Portfolio <hello@yourdomain.com>"

# 21st.dev registry key — used by the "@21st" registry in components.json so
# `shadcn add @21st/<author>/<slug>` authenticates without pasting the key.
# Get/rotate it in your 21st.dev account settings. Keep it in .env.local only.
TWENTY_FIRST_API_KEY=
